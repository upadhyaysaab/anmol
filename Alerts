# FOR MEMORY ALERTS ##

#!/bin/bash

# Get free memory in MB
FREE_MEM=$(free -mt | grep "Total:" | awk '{print $4}')
TH=10  # Threshold in MB

if [[ "$FREE_MEM" -lt "$TH" ]]; then
    echo "⚠️ Kindly adjust your RAM. Free memory is ${FREE_MEM} MB"
else
    echo "✅ Everything is fine. Free memory is ${FREE_MEM} MB"
fi

