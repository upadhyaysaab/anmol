### WITHCLOUD WATCH AND SNS ##

#!/bin/bash

PARTITION="/"
THRESHOLD=12
SNS_TOPIC_ARN="arn:aws:sns:us-east-1:123456789012:MyAlerts"

# Get disk usage %
USAGE=$(df -k | grep "$PARTITION" | awk '{print $5}' | tr -d '%')

# Push metric to CloudWatch
aws cloudwatch put-metric-data \
    --namespace "DevOps/Metrics" \
    --metric-name "DiskUsage" \
    --value "$USAGE" \
    --unit Percent &> /dev/null

# Check threshold and send SNS alert if exceeded
if [[ "$USAGE" -ge "$THRESHOLD" ]]; then
    aws sns publish \
        --topic-arn "$SNS_TOPIC_ARN" \
        --subject "Disk Alert on $(hostname)" \
        --message "Disk usage on $PARTITION is ${USAGE}% (threshold $THRESHOLD%)" &> /dev/null
fi
