node {

    def appName = "test-app"
    def imageTag = "latest"

    // 🔥 FORCE JAVA 21 HERE
    def JAVA_HOME = "/usr/lib/jvm/java-21-amazon-corretto"

    try {

        stage('Setup Environment') {
            sh """
            export JAVA_HOME=${JAVA_HOME}
            export PATH=$JAVA_HOME/bin:$PATH

            java -version
            javac -version
            mvn -version
            """
        }

        stage('Checkout') {
            checkout scm
        }

        dir('TEST') {

            stage('Build') {
                sh """
                export JAVA_HOME=${JAVA_HOME}
                export PATH=$JAVA_HOME/bin:$PATH
                mvn clean package
                """
            }

            stage('Unit Test') {
                sh """
                export JAVA_HOME=${JAVA_HOME}
                export PATH=$JAVA_HOME/bin:$PATH
                mvn test
                """
            }

            stage('JaCoCo Report') {
                sh """
                export JAVA_HOME=${JAVA_HOME}
                export PATH=$JAVA_HOME/bin:$PATH
                mvn jacoco:report
                """
            }

            stage('SonarQube Analysis') {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    sh """
                    export JAVA_HOME=${JAVA_HOME}
                    export PATH=$JAVA_HOME/bin:$PATH

                    mvn sonar:sonar \
                    -Dsonar.host.url=http://3.94.203.126:9000 \
                    -Dsonar.login=admin \
                    -Dsonar.password=admin
                    """
                }
            }

            stage('Docker Build') {
                sh "docker build -t ${appName}:${imageTag} ."
            }

            stage('Run Container') {
    sh """
    docker rm -f ${appName} || true
    docker run -d -p 8081:8080 --name ${appName} ${appName}:${imageTag}
    """

    // WAIT UNTIL APP IS READY (NO sleep)
    timeout(time: 30, unit: 'SECONDS') {
        waitUntil {
            def status = sh(
                script: "curl -s http://localhost:8081/hello",
                returnStatus: true
            )
            return status == 0
        }
    }
}

stage('Integration Test - Newman') {
    sh '''
    newman run postman_collection.json \
    --env-var baseUrl=http://35.154.214.184:8081 \
    --reporters cli,html \
    --reporter-html-export newman-report.html
    '''
}
            stage('Trivy Scan') {
                catchError(buildResult: 'SUCCESS', stageResult: 'FAILURE') {
                    sh "trivy image --exit-code 1 --severity HIGH,CRITICAL ${appName}:${imageTag}"
                }
            }
        }

    } finally {

    

        junit 'TEST/target/surefire-reports/*.xml'
        archiveArtifacts artifacts: 'TEST/newman-report.html', fingerprint: true
    }
}
