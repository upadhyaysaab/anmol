{
  "info": {
    "name": "Hello API",
    "_postman_id": "123456",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Hello",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:8080/hello",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "8080",
          "path": [
            "hello"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Body check', function () {",
              "    pm.expect(pm.response.text()).to.eql('Hello Jenkins Integration Test');",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
